<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.smartlibrary.controller.NotificationsController"
      spacing="18"
      styleClass="page">
    <padding>
        <Insets top="28" right="30" bottom="30" left="30"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Centre de notifications" styleClass="page-title"/>
            <Label text="Historique des succès, erreurs, alertes et informations de l'application." styleClass="page-subtitle"/>
        </VBox>
        <Button text="Vider" onAction="#clearNotifications" styleClass="danger-button"/>
    </HBox>

    <HBox spacing="10">
        <Button text="Succès" onAction="#demoSuccess" styleClass="success-button"/>
        <Button text="Avertissement" onAction="#demoWarning" styleClass="warning-button"/>
        <Button text="Erreur" onAction="#demoError" styleClass="danger-button"/>
        <Button text="Info" onAction="#demoInfo" styleClass="secondary-button"/>
    </HBox>

    <ListView fx:id="notificationsListView" VBox.vgrow="ALWAYS" styleClass="notification-list"/>
</VBox>
