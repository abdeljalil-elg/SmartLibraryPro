<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.smartlibrary.controller.SettingsController"
      spacing="18"
      styleClass="page">
    <fx:define>
        <ToggleGroup fx:id="themeGroup"/>
    </fx:define>
    <padding>
        <Insets top="28" right="30" bottom="30" left="30"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Paramètres" styleClass="page-title"/>
            <Label text="Personnalisation visuelle, animations et état de la connexion MySQL." styleClass="page-subtitle"/>
        </VBox>
        <Button text="Réinitialiser" onAction="#resetPreferences" styleClass="secondary-button"/>
        <Button text="Sauvegarder" onAction="#savePreferences" styleClass="primary-button"/>
    </HBox>

    <Accordion VBox.vgrow="ALWAYS">
        <panes>
            <TitledPane text="Apparence" expanded="true">
                <VBox spacing="16" styleClass="pane-content">
                    <HBox spacing="18">
                        <RadioButton fx:id="darkRadio" text="Mode sombre" toggleGroup="$themeGroup"/>
                        <RadioButton fx:id="lightRadio" text="Mode clair" toggleGroup="$themeGroup"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="Couleur d'accent" styleClass="field-label"/>
                        <ColorPicker fx:id="accentColorPicker"/>
                    </HBox>
                    <VBox spacing="8">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Taille de police" styleClass="field-label"/>
                            <Label fx:id="fontSizeLabel" text="14 px" styleClass="pill-label"/>
                        </HBox>
                        <Slider fx:id="fontSizeSlider" min="12" max="18" majorTickUnit="1" minorTickCount="0" showTickMarks="true" showTickLabels="true"/>
                        <ProgressBar fx:id="fontPreviewProgressBar" maxWidth="Infinity"/>
                    </VBox>
                </VBox>
            </TitledPane>

            <TitledPane text="Comportement">
                <VBox spacing="16" styleClass="pane-content">
                    <CheckBox fx:id="animationsCheckBox" text="Activer les animations et micro-interactions"/>
                    <Label text="Les animations restent discrètes: transitions de page, compteurs KPI et notifications toast." styleClass="muted-label"/>
                </VBox>
            </TitledPane>

            <TitledPane text="Base de données">
                <VBox spacing="12" styleClass="pane-content">
                    <Label text="URL JDBC" styleClass="field-label"/>
                    <Label fx:id="dbUrlLabel" wrapText="true" styleClass="code-label"/>
                    <Label text="Utilisateur" styleClass="field-label"/>
                    <Label fx:id="dbUserLabel" styleClass="code-label"/>
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Button text="Tester la connexion" onAction="#testConnection" styleClass="secondary-button"/>
                        <Label fx:id="connectionStateLabel" text="Non testé"/>
                    </HBox>
                </VBox>
            </TitledPane>
        </panes>
    </Accordion>
</VBox>
