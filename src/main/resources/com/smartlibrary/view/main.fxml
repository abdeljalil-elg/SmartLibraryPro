<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.smartlibrary.controller.MainController"
           styleClass="app-root">
    <BorderPane fx:id="shell" styleClass="shell">
        <top>
            <MenuBar styleClass="top-menu">
                <Menu text="Fichier">
                    <MenuItem text="Actualiser connexion MySQL" onAction="#onRefreshConnection"/>
                    <MenuItem text="Quitter" onAction="#onExit"/>
                </Menu>
                <Menu text="Navigation">
                    <MenuItem text="Tableau de bord" onAction="#openDashboard"/>
                    <MenuItem text="Livres" onAction="#openBooks"/>
                    <MenuItem text="Emprunts" onAction="#openLoans"/>
                    <MenuItem text="Statistiques" onAction="#openStatistics"/>
                </Menu>
                <Menu text="Aide">
                    <MenuItem text="Centre d'aide" onAction="#openHelp"/>
                    <MenuItem text="À propos" onAction="#onAboutDialog"/>
                </Menu>
            </MenuBar>
        </top>
        <left>
            <VBox styleClass="sidebar" spacing="14">
                <padding>
                    <Insets top="22" right="18" bottom="18" left="18"/>
                </padding>
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="brand-row">
                    <StackPane styleClass="brand-mark">
                        <Label text="SL" styleClass="brand-mark-text"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="SmartLibrary" styleClass="brand-title"/>
                        <Label text="Pro Console" styleClass="brand-subtitle"/>
                    </VBox>
                </HBox>

                <Separator/>

                <VBox spacing="6">
                    <Button fx:id="dashboardButton" text="Tableau de bord" onAction="#openDashboard" maxWidth="Infinity" styleClass="nav-button">
                        <graphic><Label text="⌂" styleClass="nav-icon"/></graphic>
                    </Button>
                    <Button fx:id="booksButton" text="Livres" onAction="#openBooks" maxWidth="Infinity" styleClass="nav-button">
                        <graphic><Label text="▦" styleClass="nav-icon"/></graphic>
                    </Button>
                    <Button fx:id="loansButton" text="Emprunts" onAction="#openLoans" maxWidth="Infinity" styleClass="nav-button">
                        <graphic><Label text="↔" styleClass="nav-icon"/></graphic>
                    </Button>
                    <Button fx:id="statisticsButton" text="Statistiques" onAction="#openStatistics" maxWidth="Infinity" styleClass="nav-button">
                        <graphic><Label text="▥" styleClass="nav-icon"/></graphic>
                    </Button>
                    <Button fx:id="notificationsButton" text="Notifications" onAction="#openNotifications" maxWidth="Infinity" styleClass="nav-button">
                        <graphic><Label text="!" styleClass="nav-icon"/></graphic>
                    </Button>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <VBox spacing="6">
                    <Button fx:id="settingsButton" text="Paramètres" onAction="#openSettings" maxWidth="Infinity" styleClass="nav-button">
                        <graphic><Label text="⚙" styleClass="nav-icon"/></graphic>
                    </Button>
                    <Button fx:id="helpButton" text="Aide" onAction="#openHelp" maxWidth="Infinity" styleClass="nav-button">
                        <graphic><Label text="?" styleClass="nav-icon"/></graphic>
                    </Button>
                    <Button fx:id="aboutButton" text="À propos" onAction="#openAbout" maxWidth="Infinity" styleClass="nav-button">
                        <graphic><Label text="i" styleClass="nav-icon"/></graphic>
                    </Button>
                </VBox>

                <VBox spacing="6" styleClass="connection-card">
                    <Label text="État système" styleClass="mini-heading"/>
                    <Label fx:id="connectionStatusLabel" text="Vérification..." styleClass="status-offline"/>
                </VBox>
            </VBox>
        </left>
        <center>
            <StackPane fx:id="contentPane" styleClass="content-pane"/>
        </center>
    </BorderPane>

    <VBox fx:id="toastContainer" alignment="TOP_RIGHT" spacing="10" mouseTransparent="true" maxWidth="380"
          StackPane.alignment="TOP_RIGHT">
        <padding>
            <Insets top="54" right="28" bottom="0" left="0"/>
        </padding>
    </VBox>
</StackPane>
