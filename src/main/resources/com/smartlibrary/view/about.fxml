<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.smartlibrary.controller.AboutController"
      spacing="20"
      styleClass="page">
    <padding>
        <Insets top="28" right="30" bottom="30" left="30"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="18" styleClass="about-hero">
        <StackPane styleClass="about-logo">
            <Label text="SL" styleClass="about-logo-text"/>
        </StackPane>
        <VBox spacing="7">
            <Label text="SmartLibrary Pro" styleClass="page-title"/>
            <Label text="Application JavaFX premium de gestion de bibliothèque intelligente." styleClass="page-subtitle"/>
            <Label text="MVC · DAO · JDBC · MySQL · FXML · CSS JavaFX" styleClass="pill-label"/>
        </VBox>
    </HBox>

    <VBox spacing="12" styleClass="panel">
        <Label text="Qualité du projet" styleClass="section-title"/>
        <Label text="Architecture claire, interface moderne, préférences persistantes, exports CSV et base MySQL relationnelle." wrapText="true" styleClass="muted-label"/>
        <ProgressBar fx:id="qualityProgressBar" maxWidth="Infinity"/>
    </VBox>

    <VBox spacing="10" styleClass="panel">
        <Label text="Modules livrés" styleClass="section-title"/>
        <Label text="Dashboard, livres, emprunts, statistiques, notifications, paramètres, aide, à propos, SQL et documentation." wrapText="true"/>
        <Button text="Ouvrir le dialogue À propos" onAction="#openDialog" styleClass="primary-button"/>
    </VBox>
</VBox>
